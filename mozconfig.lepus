# Lepus Browser build configuration
# Usage: MOZCONFIG=mozconfig.lepus ./mach build

# Branding
ac_add_options --with-branding=browser/branding/lepus

# Build type
ac_add_options --enable-optimize
ac_add_options --disable-debug

# Disable telemetry and crash reporting for the fork
ac_add_options --disable-crashreporter
ac_add_options --disable-telemetry
ac_add_options --disable-updater

# Keep developer tools enabled
ac_add_options --enable-devtools
